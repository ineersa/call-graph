#!/usr/bin/env php
<?php declare(strict_types=1);

use CallGraph\Viz\CallGraphLoader;
use CallGraph\Viz\DotRenderer;

require $_composer_autoload_path ?? __DIR__ . '/../vendor/autoload.php';

$options = getopt(
    'hi:d:s:m:I:E:n:w:p:k:',
    [
        'help',
        'input:',
        'dot:',
        'svg:',
        'mode:',
        'include:',
        'exclude:',
        'max-nodes:',
        'min-edge-weight:',
        'namespace-depth:',
        'engine:',
        'no-cluster',
        'include-functions',
    ]
);

if (!is_array($options)) {
    fwrite(STDERR, "Failed to parse CLI options." . PHP_EOL);
    exit(2);
}

if (isset($options['h']) || isset($options['help'])) {
    printHelp();
    exit(0);
}

$input = optionValue($options, ['i', 'input'], 'callgraph.json');
$dotPath = optionValue($options, ['d', 'dot'], 'callgraph.dot');
$svgPath = optionValue($options, ['s', 'svg'], null);
$mode = optionValue($options, ['m', 'mode'], 'class');
$includePattern = optionValue($options, ['I', 'include'], null);
$excludePattern = optionValue($options, ['E', 'exclude'], null);
$clusterByNamespace = !isset($options['no-cluster']);
$includeFunctions = isset($options['include-functions']);
$engine = optionValue($options, ['k', 'engine'], 'dot');

$maxNodesRaw = optionValue($options, ['n', 'max-nodes'], null);
$minEdgeWeightRaw = optionValue($options, ['w', 'min-edge-weight'], '1');
$namespaceDepthRaw = optionValue($options, ['p', 'namespace-depth'], '2');
$maxNodes = null;
if ($maxNodesRaw !== null) {
    if (!ctype_digit($maxNodesRaw) || (int) $maxNodesRaw < 1) {
        fwrite(STDERR, "--max-nodes must be a positive integer." . PHP_EOL);
        exit(2);
    }
    $maxNodes = (int) $maxNodesRaw;
}

if (!ctype_digit($minEdgeWeightRaw) || (int) $minEdgeWeightRaw < 1) {
    fwrite(STDERR, "--min-edge-weight must be a positive integer." . PHP_EOL);
    exit(2);
}

if (!ctype_digit($namespaceDepthRaw) || (int) $namespaceDepthRaw < 1) {
    fwrite(STDERR, "--namespace-depth must be a positive integer." . PHP_EOL);
    exit(2);
}

if ($engine === null || !in_array($engine, ['dot', 'sfdp', 'fdp', 'neato'], true)) {
    fwrite(STDERR, "--engine must be one of: dot, sfdp, fdp, neato." . PHP_EOL);
    exit(2);
}

$minEdgeWeight = (int) $minEdgeWeightRaw;
$namespaceDepth = (int) $namespaceDepthRaw;

try {
    $loader = new CallGraphLoader();
    $edges = $loader->loadFromFile($input);

    $renderer = new DotRenderer(
        $mode,
        $includePattern,
        $excludePattern,
        $maxNodes,
        $clusterByNamespace,
        $includeFunctions,
        $namespaceDepth,
        $minEdgeWeight
    );
    $dot = $renderer->render($edges);

    file_put_contents($dotPath, $dot);

    if ($svgPath !== null) {
        renderSvg($dotPath, $svgPath, $engine);
    }

    $stats = $renderer->getLastStats();
    fwrite(STDOUT, 'Wrote ' . $dotPath . PHP_EOL);
    fwrite(
        STDOUT,
        'Nodes: ' . $stats['renderedNodes']
        . ', edges: ' . $stats['renderedEdges']
        . ', filtered: ' . $stats['droppedByFilter']
        . ', functions: ' . $stats['droppedByFunction']
        . ', low-weight: ' . $stats['droppedByMinEdgeWeight']
        . ', trimmed: ' . $stats['droppedByMaxNodes']
        . PHP_EOL
    );

    if ($svgPath !== null) {
        fwrite(STDOUT, 'Wrote ' . $svgPath . PHP_EOL);
    }
} catch (Throwable $exception) {
    fwrite(STDERR, 'Error: ' . $exception->getMessage() . PHP_EOL);
    exit(1);
}

/**
 * @param array<string, mixed> $options
 * @param list<string> $keys
 */
function optionValue(array $options, array $keys, ?string $default): ?string
{
    foreach ($keys as $key) {
        if (!array_key_exists($key, $options)) {
            continue;
        }

        $value = $options[$key];
        if ($value === false || $value === null) {
            return $default;
        }

        if (is_string($value) && $value !== '') {
            return $value;
        }
    }

    return $default;
}

function renderSvg(string $dotPath, string $svgPath, string $engine): void
{
    if (!binaryExists($engine)) {
        throw new RuntimeException('Graphviz engine was not found in PATH: ' . $engine);
    }

    $flags = $engine === 'dot' ? '-Gnewrank=true ' : '';
    $output = [];
    $exitCode = 0;
    $command = $engine . ' -Tsvg ' . $flags . escapeshellarg($dotPath) . ' -o ' . escapeshellarg($svgPath);
    exec($command . ' 2>&1', $output, $exitCode);

    if ($exitCode === 0) {
        return;
    }

    $errorText = implode(PHP_EOL, $output);
    if ($engine === 'dot' && str_contains($errorText, 'trouble in init_rank') && binaryExists('sfdp')) {
        fwrite(STDERR, "dot failed with init_rank; retrying with sfdp fallback." . PHP_EOL);

        $fallbackOutput = [];
        $fallbackExitCode = 0;
        $fallbackCommand = 'sfdp -Tsvg ' . escapeshellarg($dotPath) . ' -o ' . escapeshellarg($svgPath);
        exec($fallbackCommand . ' 2>&1', $fallbackOutput, $fallbackExitCode);

        if ($fallbackExitCode === 0) {
            return;
        }

        $errorText .= PHP_EOL . 'sfdp fallback failed:' . PHP_EOL . implode(PHP_EOL, $fallbackOutput);
    }

    throw new RuntimeException('Graphviz failed: ' . $errorText);
}

function binaryExists(string $binary): bool
{
    $output = [];
    $exitCode = 0;
    exec('command -v ' . escapeshellarg($binary), $output, $exitCode);

    return $exitCode === 0;
}

function printHelp(): void
{
    $help = <<<'TXT'
Generate a Graphviz DOT call graph from callgraph.json.

Usage:
  callgraph-viz [options]

Options:
  -i, --input <file>        Input JSON file (default: callgraph.json)
  -d, --dot <file>          Output DOT file (default: callgraph.dot)
  -s, --svg <file>          Also render SVG through Graphviz dot
  -m, --mode <class|method|namespace>
                             Group nodes by class, method, or namespace (default: class)
  -I, --include <regex>     Keep edges where either side matches regex
  -E, --exclude <regex>     Drop edges where either side matches regex
  -n, --max-nodes <count>   Keep top N nodes by edge frequency
  -w, --min-edge-weight <n> Hide edges with fewer than N calls (default: 1)
  -p, --namespace-depth <n> Namespace segment depth for namespace mode (default: 2)
  -k, --engine <name>       Graphviz engine: dot, sfdp, fdp, neato (default: dot)
      --no-cluster          Disable namespace cluster boxes
      --include-functions   Include function nodes/edges (excluded by default)
  -h, --help                Show this help

Examples:
  callgraph-viz
  callgraph-viz --mode method --dot detailed.dot
  callgraph-viz --include-functions --mode method
  callgraph-viz --mode namespace --namespace-depth 3 --min-edge-weight 2 --max-nodes 120
  callgraph-viz --engine sfdp --svg callgraph.svg
  callgraph-viz -I '/^App\\\\/' -E '/\\\\Tests\\\\/' --svg callgraph.svg
TXT;

    fwrite(STDOUT, $help . PHP_EOL);
}
